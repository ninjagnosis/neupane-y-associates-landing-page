    "@fontsource-variable/fraunces": "^5.1.2",
    "@fontsource-variable/inter": "^5.1.2",
    "@iconify-json/lucide": "^1.2.20",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.6.1",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.2",
