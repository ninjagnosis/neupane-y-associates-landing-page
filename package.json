{
  "name": "neupane-y-associates",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Neupane Y. & Associates — Chartered Accountants website",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
