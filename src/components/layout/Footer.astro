---
import Container from '@components/ui/Container.astro';
import { Icon } from 'astro-icon/components';
import { site, nav } from '@data/site';

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ink-deep)] text-[var(--color-bone)] relative overflow-hidden">
  <!-- Subtle ledger lines background -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.06] pointer-events-none"
    style="background-image: repeating-linear-gradient(to bottom, transparent 0, transparent 31px, var(--color-bone) 31px, var(--color-bone) 32px);"
  ></div>

  <Container size="xl" class="relative">
    <!-- Big CTA strip -->
    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-20 pt-24 lg:pt-32 pb-16 border-b border-[var(--color-bone)]/12">
      <div>
        <span class="eyebrow eyebrow--on-dark">A conversation, not a sales call</span>
        <h2 class="display-2 mt-6 text-[var(--color-bone)]">
          Numbers tell a story.
          <br />
          <span class="accent-italic accent-italic--on-dark">Ours starts with yours.</span>
        </h2>
      </div>
      <div class="flex flex-col justify-end gap-6">
        <p class="text-[var(--color-bone)]/70 max-w-md leading-relaxed">
          Tell us about your business, your filing season, or the question keeping
          you up the night before a board meeting. We will take it from there.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact/" class="btn btn--on-dark">
            Start the conversation
            <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
          </a>
          <a href={`tel:${site.phoneRaw}`} class="btn btn--ghost-on-dark">
            <Icon name="lucide:phone" class="w-3.5 h-3.5" />
            {site.phone}
          </a>
        </div>
      </div>
    </div>

    <!-- Footer columns -->
    <div class="grid lg:grid-cols-[1.4fr_1fr_1fr_1fr] gap-12 lg:gap-16 py-16">
      <div class="flex flex-col gap-6">
        <div class="flex items-baseline gap-3 text-[var(--color-bone)]">
          <span class="font-serif text-[2.25rem] leading-none tracking-tight" style="font-variation-settings: 'opsz' 96, 'SOFT' 30;">
            NY<span class="accent-italic accent-italic--on-dark">&amp;</span>A
          </span>
          <span class="text-xs uppercase tracking-[0.2em] opacity-70">Est. {site.founded}</span>
        </div>
        <p class="text-[var(--color-bone)]/65 text-sm leading-relaxed max-w-xs">
          A boutique chartered accountancy practice in Bhaktapur, serving Nepali
          businesses with audit, tax and advisory services since {site.founded}.
        </p>
        <div class="flex gap-2 mt-2">
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noreferrer noopener"
            aria-label="Facebook"
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--color-bone)]/20 hover:bg-[var(--color-bone)] hover:text-[var(--color-ink)] transition-colors"
          >
            <Icon name="lucide:facebook" class="w-4 h-4" />
          </a>
          <a
            href={site.social.linkedin}
            aria-label="LinkedIn"
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--color-bone)]/20 hover:bg-[var(--color-bone)] hover:text-[var(--color-ink)] transition-colors"
          >
            <Icon name="lucide:linkedin" class="w-4 h-4" />
          </a>
          <a
            href={`mailto:${site.email}`}
            aria-label="Email"
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--color-bone)]/20 hover:bg-[var(--color-bone)] hover:text-[var(--color-ink)] transition-colors"
          >
            <Icon name="lucide:mail" class="w-4 h-4" />
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-soft)] mb-5 font-sans">Services</h4>
        <ul class="space-y-3">
          {
            nav.footer.services.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-[var(--color-bone)]/75 hover:text-[var(--color-bone)] anim-underline"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-soft)] mb-5 font-sans">Firm</h4>
        <ul class="space-y-3">
          {
            nav.footer.firm.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-[var(--color-bone)]/75 hover:text-[var(--color-bone)] anim-underline"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-soft)] mb-5 font-sans">Visit</h4>
        <address class="not-italic text-sm text-[var(--color-bone)]/75 leading-relaxed">
          {site.address.line1}<br />
          {site.address.line2}<br />
          {site.address.country}
        </address>
        <div class="mt-5 space-y-2 text-sm">
          <a href={`tel:${site.phoneRaw}`} class="block text-[var(--color-bone)]/75 hover:text-[var(--color-bone)]">
            {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="block text-[var(--color-bone)]/75 hover:text-[var(--color-bone)] break-all">
            {site.email}
          </a>
        </div>
        <p class="mt-5 text-xs text-[var(--color-bone)]/55 leading-relaxed">
          {site.hours.weekdays}<br />
          {site.hours.weekend}
        </p>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-4 py-8 border-t border-[var(--color-bone)]/12 text-xs text-[var(--color-bone)]/55">
      <p>© {year} {site.name}. All rights reserved.</p>
      <p class="font-serif italic text-[var(--color-bone)]/70" style="font-variation-settings: 'opsz' 24, 'SOFT' 60;">
        {site.promise}
      </p>
    </div>
  </Container>
</footer>
