---
import Container from '@components/ui/Container.astro';
import Wordmark from '@components/ui/Wordmark.astro';
import { Icon } from 'astro-icon/components';
import { nav } from '@data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-500" data-state="top">
  <div
    class="site-header-bar border-b border-transparent transition-[background,backdrop-filter,border-color] duration-500"
  >
    <Container size="xl" class="flex items-center justify-between py-5">
      <Wordmark size="md" />

      <nav aria-label="Primary" class="hidden lg:flex items-center gap-1">
        {
          nav.primary.map((item) => (
            <a
              href={item.href}
              class:list={[
                'relative px-4 py-2 text-sm font-medium tracking-tight transition-colors',
                'text-[var(--color-ink)] hover:text-[var(--color-gold-deep)]',
                isActive(item.href) && 'text-[var(--color-gold-deep)]',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
              {isActive(item.href) && (
                <span class="absolute left-1/2 -translate-x-1/2 bottom-0.5 h-px w-6 bg-[var(--color-gold-deep)]" />
              )}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-3">
        <a href="/contact/" class="btn hidden md:inline-flex">
          Book consultation
          <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
        </a>

        <button
          type="button"
          id="mobile-menu-trigger"
          class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-full border border-[var(--color-ink)]/15"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Open menu"
        >
          <Icon name="lucide:menu" class="w-5 h-5" />
        </button>
      </div>
    </Container>
  </div>
</header>

<!-- Mobile slide-over -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden"
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-[var(--color-ink-deep)]/50 backdrop-blur-sm" data-menu-close></div>
  <div class="absolute inset-y-0 right-0 w-full max-w-md bg-[var(--color-bone)] shadow-2xl flex flex-col">
    <div class="flex items-center justify-between px-6 py-5 border-b border-[var(--color-ink)]/10">
      <Wordmark size="sm" />
      <button
        type="button"
        class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[var(--color-ink)]/15"
        data-menu-close
        aria-label="Close menu"
      >
        <Icon name="lucide:x" class="w-5 h-5" />
      </button>
    </div>

    <nav aria-label="Mobile" class="flex-1 overflow-y-auto px-6 py-8 flex flex-col">
      {
        nav.primary.map((item, i) => (
          <a
            href={item.href}
            class="group flex items-baseline justify-between border-b border-[var(--color-ink)]/10 py-5"
          >
            <span class="font-serif text-3xl tracking-tight" style="font-variation-settings: 'opsz' 48, 'SOFT' 20;">
              <span class="text-[var(--color-gold-deep)] mr-3 text-xs font-sans uppercase tracking-[0.2em]" style="font-variation-settings: normal;">
                0{i + 1}
              </span>
              {item.label}
            </span>
            <Icon name="lucide:arrow-up-right" class="w-5 h-5 text-[var(--color-stone-400)] group-hover:text-[var(--color-ink)] transition-colors" />
          </a>
        ))
      }
      <a href="/contact/" class="btn mt-10 self-start">
        Book consultation
        <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
      </a>
    </nav>
  </div>
</div>

<style>
  /* Top state — fully transparent over hero */
  #site-header[data-state='top'] .site-header-bar {
    background: transparent;
    border-bottom-color: transparent;
  }
  /* Scrolled state — light frosted with hairline rule */
  #site-header[data-state='scrolled'] .site-header-bar {
    background: color-mix(in srgb, var(--color-bone) 78%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom-color: color-mix(in srgb, var(--color-ink) 8%, transparent);
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;

    const update = () => {
      const scrolled = window.scrollY > 24;
      header.setAttribute('data-state', scrolled ? 'scrolled' : 'top');
    };

    update();
    window.addEventListener('scroll', update, { passive: true });

    // Mobile menu
    const trigger = document.getElementById('mobile-menu-trigger');
    const menu = document.getElementById('mobile-menu');
    if (!trigger || !menu) return;

    const open = () => {
      menu.classList.remove('hidden');
      menu.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      document.documentElement.style.overflow = 'hidden';
    };

    const close = () => {
      menu.classList.add('hidden');
      menu.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';
    };

    trigger.addEventListener('click', open);
    menu.querySelectorAll('[data-menu-close]').forEach((el) =>
      el.addEventListener('click', close),
    );
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) close();
    });
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
