---
interface Props {
  as?: 'div' | 'section' | 'article' | 'header' | 'footer' | 'nav' | 'main';
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'wide';
  class?: string;
}

const { as: Tag = 'div', size = 'lg', class: className = '' } = Astro.props;

const sizes = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-7xl',
  xl: 'max-w-[88rem]',
  wide: 'max-w-[96rem]',
};
---

<Tag class={`mx-auto w-full px-6 sm:px-8 lg:px-12 ${sizes[size]} ${className}`}>
  <slot />
</Tag>
