---
import { site } from '@data/site';

interface Props {
  variant?: 'default' | 'on-dark';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'default', size = 'md', class: className = '' } = Astro.props;

const colorClass = variant === 'on-dark' ? 'text-[var(--color-bone)]' : 'text-[var(--color-ink)]';
const sizes = {
  sm: 'text-[1rem]',
  md: 'text-[1.125rem]',
  lg: 'text-[1.375rem]',
};
---

<a href="/" aria-label={`${site.name} — home`} class={`group inline-flex items-baseline gap-3 ${colorClass} ${className}`}>
  <span class="font-serif tracking-tight leading-none" style="font-variation-settings: 'opsz' 48, 'SOFT' 30; font-size: 1.5em;">
    NY<span class="accent-italic" style={variant === 'on-dark' ? 'color: var(--color-gold-soft)' : 'color: var(--color-gold-deep)'}>&amp;</span>A
  </span>
  <span class={`${sizes[size]} hidden sm:inline-flex flex-col leading-[1.1] font-sans`}>
    <span class="font-medium tracking-tight">Neupane Y. &amp; Associates</span>
    <span class="text-[0.625rem] uppercase tracking-[0.18em] opacity-70 font-medium">Chartered Accountants</span>
  </span>
</a>
