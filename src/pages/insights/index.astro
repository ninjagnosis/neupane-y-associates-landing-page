---
import Base from '@layouts/Base.astro';
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import Reveal from '@components/ui/Reveal.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const allInsights = (await getCollection('insights'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = 'Insights & Resources | Accounting Tips & Tax News';
const description = 'Read our latest insights on Nepal tax compliance, audit readiness, VAT registration, and accounting best practices for Nepali businesses.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://neupaneassociates.com.np' },
    { '@type': 'ListItem', position: 2, name: 'Insights', item: 'https://neupaneassociates.com.np/insights/' },
  ],
};
---

<Base {title} {description} jsonLd={jsonLd}>
  <section class="pt-32 pb-20 lg:pt-48 lg:pb-32">
    <Container size="lg">
      <Reveal class="max-w-3xl">
        <h1 class="display-1">
          Financial updates,
          <br />
          <span class="accent-italic">thinking ahead</span>
        </h1>
      </Reveal>
      <Reveal delay={1} class="mt-8 max-w-2xl">
        <p class="lead text-[var(--color-stone-500)]">
          Insights on tax changes, audit best practices, and strategic financial decisions for Nepali businesses.
        </p>
      </Reveal>
    </Container>
  </section>

  <section class="section">
    <Container size="lg">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        {
          allInsights.map((post, i) => (
            <Reveal
              delay={(i % 5) as 0 | 1 | 2 | 3 | 4 | 5}
              as="article"
              class="flex flex-col h-full group"
            >
              <a href={`/insights/${post.slug}/`} class="block mb-6 overflow-hidden rounded-lg">
                <img
                  src={post.data.heroImage}
                  alt={post.data.heroAlt}
                  class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </a>
              <div class="flex flex-col gap-3 flex-1">
                <div class="flex items-center gap-2 text-xs text-[var(--color-stone-500)] uppercase tracking-[0.1em]">
                  <span>{post.data.category}</span>
                  <span>•</span>
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                </div>
                <a href={`/insights/${post.slug}/`} class="font-serif text-2xl leading-tight group-hover:text-[var(--color-gold)] transition-colors" style="font-variation-settings: 'opsz' 48;">
                  {post.data.title}
                </a>
                <p class="text-[var(--color-stone-500)] text-sm leading-relaxed flex-1">
                  {post.data.summary}
                </p>
                <div class="flex items-center justify-between mt-4 pt-4 border-t border-[var(--color-stone-200)]">
                  <span class="text-xs text-[var(--color-stone-400)]">{post.data.readingTime}</span>
                  <a
                    href={`/insights/${post.slug}/`}
                    class="inline-flex gap-2 text-xs font-medium uppercase tracking-[0.08em] text-[var(--color-ink)] group-hover:text-[var(--color-gold)] transition-colors"
                  >
                    Read
                    <Icon name="lucide:arrow-right" class="w-3 h-3" />
                  </a>
                </div>
              </div>
            </Reveal>
          ))
        }
      </div>
    </Container>
  </section>
</Base>
